{
  "name": "ccia-landlease",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/fix-workbox-tsconfigs.mjs && node scripts/fix-next-themes-react19.mjs",
    "convex:dev": "node scripts/convex-with-local-env.cjs dev",
    "convex:dashboard": "node scripts/convex-with-local-env.cjs dashboard",
    "verify:graph": "node scripts/verify-graph-convex.mjs",
    "verify:graph:probe": "node scripts/verify-graph-convex.mjs --probe",
    "convex:push": "node scripts/convex-with-local-env.cjs dev --once",
    "convex:deploy:prod": "npx convex deploy --yes",
    "seed:dev": "node scripts/convex-with-local-env.cjs run seed:seedCommunityOperatorsAndAdmins",
    "seed:prod": "npx convex run seed:seedCommunityOperatorsAndAdmins --prod",
    "seed:curriculum:prod": "npx convex run seed:seedLandLeaseCurriculum --prod",
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration:graph-resend": "vitest run convex/lib/integration.graphResend.test.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@livekit/components-react": "^2.9.20",
    "@livekit/components-styles": "^1.2.0",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.34.1",
    "cookie": "^1.1.1",
    "date-fns": "^4.1.0",
    "http-status-codes": "^2.3.0",
    "livekit-client": "^2.17.3",
    "livekit-server-sdk": "^2.15.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.58.1",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie": "^0.6.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
